// Two Sum 
// Given an array of integers nums and an integer target, return the indices i and j such that nums[i] + nums[j] == target and i != j.

You may assume that every input has exactly one pair of indices i and j that satisfy the condition.

Return the answer with the smaller index first.


// Solution : 

class Solution:{}
public : 
      vector<int> TwoSum(vector<int> nums, int target)
      {
            unordered_map<int,int> mp;   //declare map

            for(int i=0;i<nums.size();i++)   // for loop 
            {
                 int check = target - nums[i];   // target element and removing the current element will give the other element 
                 if(mp.find[check]!=mp.end())    
                 {
                      return{mp[check],i};   // returning indices 
                 }
                 mp[check]=i;
            }
            return{};
         }
      };
